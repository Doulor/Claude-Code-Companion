{
  "name": "Session Logger",
  "nameZh": "会话日志",
  "description": "Logs Clawd events to a local file with configurable format.",
  "descriptionZh": "将 Clawd 事件记录到本地文件，支持自定义格式。",
  "events": ["session_start", "done", "error", "tool_start", "tool_end"],
  "permissions": ["filesystem"],
  "timeoutMs": 5000,
  "settings": [
    {
      "key": "logPath",
      "label": "Log file path",
      "type": "text",
      "default": "clawd-events.log",
      "description": "Relative to plugin directory"
    },
    {
      "key": "format",
      "label": "Output format",
      "type": "select",
      "default": "json",
      "options": [
        { "label": "JSON Lines", "value": "json" },
        { "label": "Plain text", "value": "text" }
      ]
    },
    {
      "key": "includeDetail",
      "label": "Include event detail",
      "type": "toggle",
      "default": false
    }
  ]
}
